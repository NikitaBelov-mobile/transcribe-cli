<Application
    x:Class="TranscribeDesktop.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentPrimaryColor">#FF0EA5E9</Color>
            <Color x:Key="AccentSuccessColor">#FF22C55E</Color>
            <Color x:Key="AppBackgroundColor">#FF0F172A</Color>
            <Color x:Key="AppPanelColor">#FF1E293B</Color>
            <Color x:Key="AppTextColor">#FFF1F5F9</Color>
            <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
            <SolidColorBrush x:Key="AccentSuccessBrush" Color="{StaticResource AccentSuccessColor}" />
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="AppPanelBrush" Color="{StaticResource AppPanelColor}" />
            <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />

            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#FF334155" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="#FF475569" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="#FF334155" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="#FF475569" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="ListView">
                <Setter Property="Background" Value="#FF0F172A" />
                <Setter Property="BorderBrush" Value="#FF475569" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
