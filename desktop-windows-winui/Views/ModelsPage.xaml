<Page
    x:Class="TranscribeDesktop.WinUI.Views.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Models" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AppTextBrush}" />

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="InstalledCombo" Grid.Column="0" PlaceholderText="Installed models" />
            <ComboBox x:Name="PresetCombo" Grid.Column="1" Margin="10,0,0,0" PlaceholderText="Preset models" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="10,0,0,0">
                <Button Content="Set default" Click="SetDefaultButton_Click" />
                <Button Content="Install" Click="InstallButton_Click" />
                <Button Content="Refresh" Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="0,14,0,0" Padding="16" Background="{StaticResource AppPanelBrush}" CornerRadius="12">
            <StackPanel Spacing="10">
                <TextBlock x:Name="ModelsDirText" Foreground="#FFE2E8F0" />
                <TextBlock x:Name="DefaultModelText" Foreground="#FFE2E8F0" />
                <ListView x:Name="InstalledList" Height="420">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Width="260" Text="{Binding Name}" Foreground="#FFBAE6FD" />
                                <TextBlock Width="140" Text="{Binding Size}" Foreground="#FFE2E8F0" />
                                <TextBlock Text="{Binding Path}" Foreground="#FF94A3B8" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
