<Page
    x:Class="TranscribeDesktop.WinUI.Views.Onboarding.OnboardingModelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="28">
        <Border Padding="24" Background="{StaticResource AppPanelBrush}" CornerRadius="12">
            <StackPanel Spacing="14">
                <TextBlock Text="Model preparation" FontSize="30" FontWeight="Bold" Foreground="{StaticResource AppTextBrush}" />
                <TextBlock Text="Choose a model preset and install it now. This keeps onboarding focused and explicit." TextWrapping="Wrap" Foreground="#FF94A3B8" />

                <TextBlock x:Name="ModelsDirText" Foreground="#FFE2E8F0" />
                <TextBlock x:Name="DefaultModelText" Foreground="#FFE2E8F0" />

                <TextBlock Text="Available presets" Foreground="{StaticResource AppTextBrush}" />
                <ComboBox x:Name="PresetCombo" PlaceholderText="Select model preset" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Install preset" Click="InstallButton_Click" />
                    <Button Content="Refresh" Click="RefreshButton_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Button Content="Back" Click="BackButton_Click" />
                    <Button Content="Finish onboarding" Click="FinishButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
