<Window
    x:Class="TranscribeDesktop.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Transcribe Desktop">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="16,16,16,10" Padding="14" Background="{StaticResource AppPanelBrush}" CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="ConnectionText" Foreground="{StaticResource AppTextBrush}" FontSize="16" FontWeight="SemiBold" Text="Initializing..." />
                <TextBlock x:Name="SubConnectionText" Margin="0,4,0,0" Foreground="#FF94A3B8" FontSize="13" Text="Windows-first WinUI shell with onboarding flow." />
            </StackPanel>
        </Border>

        <NavigationView
            x:Name="RootNav"
            Grid.Row="1"
            Margin="16,0,16,10"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            SelectionChanged="RootNav_SelectionChanged"
            Background="Transparent">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" />
                <NavigationViewItem Content="Queue" Tag="queue" Icon="Library" />
                <NavigationViewItem Content="Models" Tag="models" Icon="AllApps" />
                <NavigationViewItem Content="Settings" Tag="settings" Icon="Setting" />
            </NavigationView.MenuItems>

            <Frame x:Name="MainFrame" />
        </NavigationView>

        <Border Grid.Row="2" Margin="16,0,16,16" Padding="10,8" Background="{StaticResource AppPanelBrush}" CornerRadius="8">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource AppTextBrush}" FontSize="12" Text="Ready" />
        </Border>
    </Grid>
</Window>
